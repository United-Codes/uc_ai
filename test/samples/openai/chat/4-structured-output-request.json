{
  "model": "gpt-4o-mini",
  "input": [
    {
      "type": "message",
      "role": "user",
      "content": [
        {
          "text": "What is the capital of France? Please respond with confidence.",
          "type": "input_text"
        }
      ]
    }
  ],
  "instructions": "You are a helpful assistant that provides accurate information.",
  "text": {
    "format": {
      "type": "json_schema",
      "name": "Response_with_confidence_score",
      "strict": true,
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "response": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "response",
          "confidence"
        ]
      }
    },
    "verbosity": "medium"
  },
  "max_tool_calls": 10,
  "store": true
}
